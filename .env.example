# InfiniteLoop Orchestrator Environment Configuration
# Copy this file to .env and customize for your setup

# =============================================================================
# LLM API Configuration
# =============================================================================

# Ollama API URL (default: http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# LM Studio API URL (OpenAI-compatible endpoint)
LMSTUDIO_API_URL=http://localhost:1234/v1

# Default model to use
DEFAULT_MODEL=gemma2:latest

# Model timeout in seconds
MODEL_TIMEOUT=120

# =============================================================================
# Resource Management
# =============================================================================

# VRAM limit in MB (default: 12288 for 12GB)
VRAM_LIMIT_MB=12288

# Memory usage threshold percentage before cooldown
MEMORY_THRESHOLD_PERCENT=90.0

# Resource monitoring poll interval in seconds
MONITOR_POLL_INTERVAL=5

# Cooldown duration in seconds when threshold exceeded
COOLDOWN_DURATION=15

# =============================================================================
# Retry and Fault Tolerance
# =============================================================================

# Maximum retry attempts for failed tasks
MAX_RETRY_ATTEMPTS=3

# Initial delay between retries in seconds
RETRY_DELAY_SECONDS=10

# Exponential backoff multiplier
RETRY_BACKOFF_MULTIPLIER=2.0

# =============================================================================
# Context Management
# =============================================================================

# Number of messages before triggering context compaction
CONTEXT_COMPACT_THRESHOLD=50

# Days to keep archived contexts
ARCHIVE_RETENTION_DAYS=30

# =============================================================================
# Memory Store Configuration
# =============================================================================

# Memory store type: json, obsidian, or hybrid
MEMORY_STORE_TYPE=json

# Obsidian vault path (optional, for obsidian store)
# Example: OBSIDIAN_VAULT_PATH=C:/Users/You/Documents/Obsidian/MyVault
# OBSIDIAN_VAULT_PATH=

# Obsidian folder within vault
OBSIDIAN_FOLDER=InfiniteLoop

# =============================================================================
# Web UI Configuration
# =============================================================================

# Web server host
WEB_HOST=0.0.0.0

# Web server port
WEB_PORT=8000

# WebSocket update interval in seconds
WS_UPDATE_INTERVAL=1.0

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file max size before rotation (bytes)
LOG_MAX_BYTES=10000000

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# =============================================================================
# Git Configuration
# =============================================================================

# Enable automatic git commits on successful operations
GIT_AUTO_COMMIT=true

# Git author name for auto-commits
GIT_AUTHOR_NAME=InfiniteLoop Orchestrator

# Git author email for auto-commits
GIT_AUTHOR_EMAIL=orchestrator@infiniteloop.local

# =============================================================================
# Surgical Edit Configuration
# =============================================================================

# Enable backup before surgical edits
SURGICAL_BACKUP_ENABLED=true

# Maximum number of backups per file
MAX_BACKUPS_PER_FILE=10
